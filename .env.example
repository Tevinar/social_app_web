# Local development environment variables for the backend
# Only put variables here that are specific to local development 
# and should not be used in other environments.

# Define the environment as 'local' to enable local development settings.
APP_ENV=local

# This variable is exposed to the client side as well, thanks to the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_APP_ENV=local

# Logging configuration
# possible values: debug, info, warn, error
LOG_LEVEL=debug

# Public base URL where the Nest backend is reachable from the web app
API_BASE_URL=http://localhost:3000

# Sentry configuration available for client and server side,
# thanks to the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_RELEASE=local-dev
