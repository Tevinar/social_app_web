{
  "name": "social_app_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.57.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "neverthrow": "^8.2.0",
    "next": "16.2.7",
    "pino": "^10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "jsx",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.(test|spec)\\.tsx?$",
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^server-only$": "<rootDir>/test/mocks/server-only.ts"
    },
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "collectCoverageFrom": [
      "**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/*.{test,spec}.{ts,tsx}"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "jsdom"
  }
}
